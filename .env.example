# Local environment variables for sigma development.
# Copy this file to `.env` when running live provider smoke tests locally.
# Do not commit real API keys.

# Required for `make openai-live`.
# Used by the ignored live OpenAI smoke tests in `tests/openai_live.rs`.
OPENAI_API_KEY=sk-your-openai-api-key

# Required for `make anthropic-live`.
# Used by the ignored live Anthropic smoke tests in `tests/anthropic_live.rs`.
ANTHROPIC_API_KEY=sk-ant-your-anthropic-api-key

# Optional Anthropic API base URL override.
# Leave unset to use the built-in default: https://api.anthropic.com
ANTHROPIC_BASE_URL=

# Optional OpenAI API base URL override.
# Leave unset to use the built-in default: https://api.openai.com/v1
OPENAI_BASE_URL=

# Optional legacy alias for OPENAI_BASE_URL.
# Used only when OPENAI_BASE_URL is unset.
OPENAI_API_BASE=

# Optional model used by `make openai-live`.
# Defaults to `gpt-4o-mini` when both model variables are unset.
SIGMA_OPENAI_TEST_MODEL=gpt-4o-mini

# Optional generic model alias for the live OpenAI smoke tests.
# Used only when SIGMA_OPENAI_TEST_MODEL is unset.
OPENAI_MODEL=

# Optional invalid model name used to verify provider business error mapping.
# Defaults to `sigma-nonexistent-openai-model`.
SIGMA_OPENAI_TEST_BAD_MODEL=sigma-nonexistent-openai-model

# Optional max completion token limit for `make openai-live`.
# Defaults to 16; keep this small to limit cost and latency.
SIGMA_OPENAI_TEST_MAX_COMPLETION_TOKENS=16

# Optional OpenAI-compatible provider base URL.
# Used by provider instances with `kind = "openai-compatible"` when api_base
# is not configured directly in ClientConfig.
OPENAI_COMPATIBLE_API_BASE=

# Optional legacy alias for OPENAI_COMPATIBLE_API_BASE.
# Used only when OPENAI_COMPATIBLE_API_BASE is unset.
OPENAI_LIKE_API_BASE=

# Optional API key for OpenAI-compatible providers.
# Some compatible endpoints do not require authentication.
OPENAI_COMPATIBLE_API_KEY=

# Optional legacy alias for OPENAI_COMPATIBLE_API_KEY.
# Used only when OPENAI_COMPATIBLE_API_KEY is unset.
OPENAI_LIKE_API_KEY=
